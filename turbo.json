{
	"$schema": "https://turborepo.dev/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**"]
		},
		"start": {
			"cache": false,
			"persistent": true
		},
		"start:dev": {
			"cache": false,
			"persistent": true
		},
		"prod": {
			"cache": false,
			"persistent": true
		},
		"postinstall": {
			"dependsOn": ["^postinstall"]
		}
	}
}
