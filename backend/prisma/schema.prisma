generator client {
  provider     = "prisma-client"
  output       = "../prisma/generated"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model CartItem {
  // Immutable fields
  id         String @id @default(uuid()) @db.Uuid
  customerId String @map("customer_id") @db.VarChar(250)

  // Mutable fields
  quantity Int @default(1) @db.Integer

  // Foreign keys
  menuItemId String @map("menu_item_id") @db.Uuid

  // Back relation fields
  menuItem MenuItem @relation(fields: [menuItemId], onDelete: Cascade, references: [id])

  // Constraints
  @@unique([customerId, menuItemId])
  @@map("cart_items")
}

model MenuCategory {
  // Immutable fields
  id String @id @default(uuid()) @db.Uuid

  // Mutable fields
  name String @unique @db.VarChar(20)

  // Front relation fields
  menuItems MenuItem[]

  // Constraints
  @@map("menu_categories")
}

model MenuItem {
  // Immutable fields
  id          String    @id @default(uuid()) @db.Uuid
  archivedAt  DateTime? @map("archived_at") @db.Timestamp() // initially null, can be set if at least 1 orderedItem is connected to this menuItem
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp()
  publishedAt DateTime? @map("published_at") @db.Timestamp() // initially null, will be set when `isVisible` is set to true for the first time

  // Mutable fields
  description    String   @db.VarChar(500)
  image          String   @db.VarChar(2048)
  inStock        Int      @default(0) @map("in_stock") @db.Integer
  isPreOrderOnly Boolean  @map("is_pre_order_only") @db.Boolean
  isVisible      Boolean  @default(false) @map("is_visible") @db.Boolean
  name           String   @db.VarChar(50)
  orderCount     Int      @default(0) @map("order_count") @db.Integer // automatically updated
  prepTime       Int      @map("prep_time") @db.Integer
  price          Decimal  @db.Decimal(10, 2)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamp()

  // Front relation fields
  cartItems         CartItem[]
  menuCategories    MenuCategory[]
  orderedItems      OrderedItem[]
  reviews           Review[]
  subscriptionItems SubscriptionItem[]

  // Constraints
  @@map("menu_items")
}

model Order {
  // Immutable fields
  id         String    @id @default(uuid()) @db.Uuid
  amount     Decimal   @db.Decimal(10, 2)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamp()
  customerId String?   @map("customer_id") @db.VarChar(250) // will be set to null if customer deletes their account
  riderId    String    @map("rider_id") @db.VarChar(250)
  orderType  OrderType @map("order_type")

  // If the type is PICKUP, the following fields will remain null
  deliveryStreet     String? @map("delivery_street") @db.VarChar(250)
  deliveryCity       String? @map("delivery_city") @db.VarChar(100)
  deliveryPostalCode String? @map("delivery_postal_code") @db.VarChar(20)
  deliveryLatitude   Float?  @map("delivery_latitude") @db.DoublePrecision
  deliveryLongitude  Float?  @map("delivery_longitude") @db.DoublePrecision

  // Mutable fields
  orderComment     String?       @map("order_comment") @db.VarChar(500) // can't modify after 7 days of order DELIVERED
  orderRating      Int?          @map("order_rating") @db.Integer // can't modify after 7 days of order DELIVERED
  orderStatus      OrderStatus   @map("order_status")
  paymentStatus    PaymentStatus @map("payment_status")
  updatedAt        DateTime      @updatedAt @map("updated_at") @db.Timestamp()
  verificationCode String?       @map("verification_code") @db.VarChar(6) // automatically updated

  // Foreign keys
  subscriptionId String? @map("subscription_id") @db.Uuid

  // Front relation fields
  orderedItems OrderedItem[]
  refunds      Refund[]

  // Back relation fields
  subscription Subscription? @relation(fields: [subscriptionId], onDelete: SetNull, references: [id])

  // Constraints
  @@map("orders")
}

model OrderedItem {
  // Immutable fields
  id       String  @id @default(uuid()) @db.Uuid
  price    Decimal @db.Decimal(10, 2)
  quantity Int     @db.Integer

  // Foreign keys
  menuItemId String @map("menu_item_id") @db.Uuid
  orderId    String @map("orderId") @db.Uuid

  // Front relation fields
  refunds Refund[]

  // Back relation fields
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])
  order    Order    @relation(fields: [orderId], references: [id])

  // Constraints
  @@unique([orderId, menuItemId])
  @@map("ordered_items")
}

model Refund {
  // Immutable fields
  id        String   @id @default(uuid()) @db.Uuid
  amount    Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp()
  reason    String?  @db.VarChar(500)

  // Foreign keys
  orderId       String  @map("order_id") @db.Uuid
  orderedItemId String? @map("ordered_item_id") @db.Uuid

  // Back relation fields
  order       Order        @relation(fields: [orderId], references: [id])
  orderedItem OrderedItem? @relation(fields: [orderedItemId], references: [id])

  // Constraints
  @@map("refunds")
}

model Review {
  // Immutable fields
  id         String   @id @default(uuid()) @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp()
  customerId String   @map("customer_id") @db.VarChar(250)

  // Mutable fields
  comment   String?  @db.VarChar(500)
  rating    Int      @db.Integer
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp()

  // Foreign keys
  menuItemId String @map("menu_item_id") @db.Uuid

  // Back relation fields
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  // Constraints
  @@unique([customerId, menuItemId])
  @@map("reviews")
}

model Subscription {
  // Immutable fields
  id         String   @id @default(uuid()) @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp()
  customerId String   @map("customer_id") @db.VarChar(250)

  // Mutable fields
  isActive     Boolean  @default(true) @map("is_active") @db.Boolean
  onMondays    Boolean  @map("on_mondays") @db.Boolean
  onTuesdays   Boolean  @map("on_tuesdays") @db.Boolean
  onWednesdays Boolean  @map("on_wednesdays") @db.Boolean
  onThursdays  Boolean  @map("on_thursdays") @db.Boolean
  onFridays    Boolean  @map("on_fridays") @db.Boolean
  onSaturdays  Boolean  @map("on_saturdays") @db.Boolean
  onSundays    Boolean  @map("on_sundays") @db.Boolean
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamp()

  // Front relation fields
  orders            Order[]
  subscriptionItems SubscriptionItem[]

  // Constraints
  @@map("subscriptions")
}

model SubscriptionItem {
  // Immutable fields
  id       String @id @default(uuid()) @db.Uuid
  quantity Int    @db.Integer

  // Foreign keys
  menuItemId     String @map("menu_item_id") @db.Uuid
  subscriptionId String @map("subscription_id") @db.Uuid

  // Back relation fields
  menuItem     MenuItem     @relation(fields: [menuItemId], onDelete: Cascade, references: [id])
  subscription Subscription @relation(fields: [subscriptionId], onDelete: Cascade, references: [id])

  // Constraints
  @@unique([subscriptionId, menuItemId])
  @@map("subscription_items")
}

enum OrderType {
  DELIVERY     @map("delivery")
  PICKUP       @map("pickup")
  WALK_IN      @map("walk_in")
  SUBSCRIPTION @map("subscription")
}

enum OrderStatus {
  // Will be set by customer
  PENDING   @map("pending") // 1st
  CANCELLED @map("cancelled") // Can't be set to CANCELLED once the status is PREPARING or later | final status

  // Will be set by restaurant
  COMPLETED  @map("completed") // 1st if WALK_IN type | final status
  REJECTED   @map("rejected") // 2nd | final status
  ACCEPTED   @map("accepted") // 2nd
  PREPARING  @map("preparing") // 3rd
  READY      @map("ready") // 4th
  PICKED_UP  @map("picked_up") // 5th if PICKUP type | final status
  IN_TRANSIT @map("in_transit") // 5th if DELIVERY type
  DELIVERED  @map("delivered") // 6th if DELIVERY type | final status

  // Special case scenario
  FAILED @map("failed") // Final status
}

enum PaymentStatus {
  FULLY_PAID     @map("fully_paid")
  PARTIALLY_PAID @map("partially_paid")
  UNPAID         @map("unpaid")
}
